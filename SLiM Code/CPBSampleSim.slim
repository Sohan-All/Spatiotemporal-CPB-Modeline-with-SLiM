// set up a simple neutral simulation
initialize()
{

    initializeSLiMOptions(nucleotideBased=T);
    defineConstant("L", initializeAncestralNucleotides("..\\data\\Genetic_Data\\refFull.fasta")); 
    initializeMutationTypeNuc("m1", 0.5, "f", 0.0);
    initializeGenomicElementType("g1", m1, 1.0, mmJukesCantor(0.0)); //1e-7
    initializeGenomicElement(g1, 0, L-1);
    initializeRecombinationRate(0); //1e-8

    /*
	// set the overall mutation rate
	initializeMutationRate(1e-7);
	// m1 mutation type: neutral
	initializeMutationType("m1", 0.5, "f", 0.0);
	// g1 genomic element type: uses m1 for all mutations
	initializeGenomicElementType("g1", m1, 1.0);
	// uniform chromosome of length 100 kb
	initializeGenomicElement(g1, 0, 99999);
	// uniform recombination along the chromosome
	initializeRecombinationRate(1e-8);
    */
}
// create a population of 500 individuals
1 early()
{
    // Read in cluster data from CSV files
    migrationRatesDF = readCSV("..\\data\\migration_rates.csv", colNames=T, sep=",");
    
    propDF = readCSV("..\\data\\cluster_data.csv", colNames=T, sep=",");

    //mutDF = readCSV("..\\data\\Genetic_Data\\mutation_lists.csv", colNames=T, sep=",");
    defineConstant("mutDF", readCSV("..\\data\\Genetic_Data\\mutation_lists.csv", colNames=T, sep=","));

    if (isNULL(mutDF) | isNULL(migrationRatesDF) | isNULL(propDF)) {
        print("Could not read one of or more of the required CSV files");
        sim.simulationFinished();
    }

    migrationRates = migrationRatesDF.asMatrix();


    // Create each subpopulation based on the amount of clusters specified
    // Sets the population of each supop to the average count of individuals in that cluster times a multiplier
    for (i in 0:(propDF.nrow-1)) {
        sim.addSubpop("p"+i, asInteger(propDF.getValue("Average Count")[i] * 100));
    }
    
    // Create a list of subpopulations which are assigned to each genome
    numGenomes = mutDF.ncol / 2;
    genomeAssignments = integer(asInteger(numGenomes)-1);
    print(length(genomeAssignments));

    for (i in 0:(propDF.nrow-1)) {
        if (propDF.getValue("Genome Assignment")[i] != "") {
            genomeAssignments[asInteger(propDF.getValue("Genome Assignment")[i])] = i;
        }
    }

    defineConstant("genomeAssignmentsConst", genomeAssignments);
    
    // Set the migration rates for each subpopulation pair based on the migration rates matrix
    for (i in 0:(ncol(migrationRates)-1)) {
        for (j in 0:(nrow(migrationRates)-1)) {
            if (i != j) 
                sim.subpopulations[i].setMigrationRates(sim.subpopulations[j], migrationRates[i+ncol(migrationRates)*j]);
        }
    }

    //Remove the first line of refFastaString which is the header
    refFastaStrings = readFile("..\\data\\Genetic_Data\\refFull.fasta");
    refFastaString = "";
    for (s in refFastaStrings) {
        if (!strprefix(s, ">")) { 
            refFastaString = refFastaString + s;
        }
    }
}

1 late() {
    print("1");
    for (i in 0:(length(genomeAssignmentsConst)-1)) {
        subpop = sim.subpopulations[genomeAssignmentsConst[i]];
        //print(genomeAssignmentsConst[i]);
        for (j in 0:(mutDF.nrow-1)) {
            toChange = mutDF.getValue("Index_" + i)[j];
            if (isNULL(toChange)) {
                break;
            }
            if (toChange == "") {
                break;
            }
            toChange = asInteger(toChange);
            newBase = mutDF.getValue("Base_" + i)[j];
            subpop.haplosomes.addNewDrawnMutation(m1, toChange, subpop, newBase); // TODO: base gets added a single position too forward
        }
    }
    print("2");
}
// run to tick 20
20 late()
{
    //sim.subpopulations[0].outputVCFSample(1);

	sim.simulationFinished();
}